# ==========================
# MANN KI BAAT - .gitignore
# ==========================

# ---- Dependencies ----
node_modules/
frontend/node_modules/
backend/node_modules/

# ---- Environment Variables (CRITICAL: contains API keys & DB credentials) ----
.env
.env.local
.env.production
.env.staging
backend/.env
frontend/.env

# ---- Build Output ----
frontend/dist/
frontend/build/
backend/dist/

# ---- Uploaded Audio Files (temp files from voice recording) ----
backend/uploads/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- OS Generated Files ----
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ---- IDE / Editor Files ----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---- Misc ----
*.tgz
*.lock
!package-lock.json
!yarn.lock
.cache/
.parcel-cache/
coverage/
